              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "sessions", "check-in"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"lotId\": \"LOT-AYALA-01\",\n  \"licensePlate\": \"DDD-3456\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Check in Jose Garcia's TRUCK. Note the sessionId in the response."
          }
        },
        {
          "name": "3. Check In – EEE-7890 (CAR)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
