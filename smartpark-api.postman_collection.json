    {
      "name": "End-to-End Flow",
      "description": "Run these requests in order to walk through a complete happy-path scenario using pre-seeded data. No setup needed — just start the app and run from top to bottom.",
      "item": [
        {
          "name": "1. Get Occupancy (before check-in)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/lots/LOT-AYALA-01/occupancy",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "lots", "LOT-AYALA-01", "occupancy"]
            },
            "description": "Confirm the lot starts at 0 occupied spaces."
          }
        },
        {
          "name": "2. Check In – DDD-3456 (TRUCK)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
