{
  "info": {
    "_postman_id": "smartpark-collection-v2",
    "name": "SmartPark API",
    "description": "Intelligent Parking Management System for Manila-scale urban areas.\n\nHow to use:\n1. Import this collection into Postman\n2. Set the `baseUrl` collection variable to `http://localhost:8080`\n3. Run requests in this order: Register Lot → Register Vehicle → Check In → Get Occupancy → Get Parked Vehicles → Check Out\n\nPre-seeded lots: LOT-AYALA-01, LOT-SMNORTH-01, LOT-BGC-01, LOT-ROBINSONS-01, LOT-GREENBELT-01\nPre-seeded vehicles: AAA-1234, BBB-5678, CCC-9012, DDD-3456, EEE-7890, FFF-1122, GGG-3344, HHH-5566, III-7788, JJJ-9900",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string",
      "description": "Base URL of the SmartPark API"
    }
  ],
  "item": [
    {
      "name": "Parking Lots",
      "description": "Endpoints for registering lots and viewing occupancy.",
      "item": [
        {
          "name": "Register Parking Lot – Success",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/lots",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "lots"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"lotId\": \"LOT-MALL-01\",\n  \"location\": \"SM Megamall, Mandaluyong City\",\n  \"capacity\": 250\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Registers a new parking lot with a client-supplied ID.\n\nExpected response: 201 Created"
          }
        },
        {
          "name": "Register Parking Lot – Duplicate ID (409)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/lots",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "lots"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"lotId\": \"LOT-AYALA-01\",\n  \"location\": \"Duplicate Location\",\n  \"capacity\": 100\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Attempts to register a lot that already exists (pre-seeded).\n\nExpected response: 409 Conflict"
          }
        },
        {
          "name": "Register Parking Lot – Validation Error (400)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/lots",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "lots"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"lotId\": \"\",\n  \"location\": \"\",\n  \"capacity\": -1\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Sends blank ID, blank location, and negative capacity.\n\nExpected response: 400 Bad Request with field-level error details"
          }
        },
        {
          "name": "Get Occupancy – LOT-AYALA-01",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/lots/LOT-AYALA-01/occupancy",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "lots", "LOT-AYALA-01", "occupancy"]
            },
            "description": "Returns current occupancy, available spaces, and occupancy percentage.\n\nExpected response: 200 OK"
          }
        },
        {
          "name": "Get Occupancy – LOT-SMNORTH-01",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/lots/LOT-SMNORTH-01/occupancy",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "lots", "LOT-SMNORTH-01", "occupancy"]
            },
            "description": "Expected response: 200 OK"
          }
        },
        {
          "name": "Get Occupancy – Not Found (404)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/lots/LOT-NONEXISTENT/occupancy",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "lots", "LOT-NONEXISTENT", "occupancy"]
            },
            "description": "Requests occupancy for a lot that does not exist.\n\nExpected response: 404 Not Found"
          }
        },
        {
          "name": "Get Parked Vehicles – LOT-AYALA-01",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/lots/LOT-AYALA-01/vehicles",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "lots", "LOT-AYALA-01", "vehicles"]
            },
            "description": "Returns all vehicles with active sessions in this lot.\n\nExpected response: 200 OK — empty array [] if no one is checked in yet"
          }
        },
        {
          "name": "Get Parked Vehicles – Not Found (404)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/lots/LOT-NONEXISTENT/vehicles",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "lots", "LOT-NONEXISTENT", "vehicles"]
            },
            "description": "Expected response: 404 Not Found"
          }
        }
      ]
    },
