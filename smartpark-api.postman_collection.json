              "options": { "raw": { "language": "json" } }
            },
            "description": "Check in Carlo Bautista's MOTORCYCLE."
          }
        },
        {
          "name": "5. Get Parked Vehicles (should show 3)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/lots/LOT-AYALA-01/vehicles",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "lots", "LOT-AYALA-01", "vehicles"]
            },
            "description": "Should return DDD-3456 (TRUCK), EEE-7890 (CAR), and FFF-1122 (MOTORCYCLE)."
          }
        },
        {
          "name": "6. Get Occupancy (should show 3 occupied)",
          "request": {
            "method": "GET",
            "header": [],
