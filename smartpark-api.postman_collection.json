            "body": {
              "mode": "raw",
              "raw": "{\n  \"lotId\": \"LOT-AYALA-01\",\n  \"licensePlate\": \"EEE-7890\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Check in Ana Villanueva's CAR."
          }
        },
        {
          "name": "4. Check In – FFF-1122 (MOTORCYCLE)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
